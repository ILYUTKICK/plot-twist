# TxLINE credentials created by the on-chain activation flow.
TXLINE_NETWORK=devnet
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_API_TOKEN=

# Ollama Cloud Story Director
AI_PROVIDER=ollama-cloud
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:20b

# ElevenLabs premium recap voice. Override the voice ID with one from your Voice Library.
ELEVENLABS_API_ORIGIN=https://api.elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_multilingual_v2

# Optional server-side override. Defaults to Solana's public devnet RPC.
SOLANA_RPC_URL=https://api.devnet.solana.com
